GEMINI_API_KEY=

PODCAST_LOOKBACK_HOURS=24
PODCAST_MAX_ARTICLES=10
PODCAST_OUTPUT_LANGUAGE=uk
PODCAST_SCRIPT_MAX_CHARS=4500

PODCAST_TTS_VOICE_1=Algenib
PODCAST_TTS_VOICE_2=Zephyr
PODCAST_TTS_STYLE="Read aloud in a casual, affirmative, business-like tone."
PODCAST_RETENTION=14

PODCAST_TITLE="News Digest"
PODCAST_DESCRIPTION="Daily AI-summarized news"
PODCAST_BASE_URL=https://example.com/podcast/
PODCAST_AUTHOR=newspodcast

# Override paths if you want files written somewhere other than ./storage/episodes
# PODCAST_EPISODES_DIR=/home/user/public_html/podcast/episodes
# PODCAST_FEED_XML=/home/user/public_html/podcast/feed.xml

# Where the Gemini prompt templates live. Default: storage/prompts/
# Edit the .txt files in this dir to tune prompts — no redeploy needed.
# PODCAST_PROMPTS_DIR=/home/user/podcast/storage/prompts
